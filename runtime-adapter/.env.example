# V4 Runtime Adapter 环境变量样例（复制为 .env 使用；勿提交真实值）

# Gateway 连接（可选：OpenClaw CLI 本机配置已可认证时无需填写）
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Adapter 行为
OPENCLAW_RUNTIME_MODE=gateway
OPENCLAW_TRANSPORT=rpc
OPENCLAW_AGENT_ID=researcher-v4
OPENCLAW_TIMEOUT=900

# Skill 入口解释器（默认 /usr/bin/python3）
CRAWL_SKILL_PYTHON=/usr/bin/python3

# crawl4more Skill（mock 联调）
USE_MOCK_CRAWLER=true
CRAWLER_DB_PATH=
