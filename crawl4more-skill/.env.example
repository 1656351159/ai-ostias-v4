# ============================================
# crawl4more Skill 环境变量示例
# 复制为 .env 并填入真实值；run.py 启动时自动加载
# ============================================

# ---------- LLM 配置（真实爬取模式必填） ----------
# LLM API Key（必填，真实模式）
AI_API_KEY=your_api_key_here
# LLM API 地址（必填，真实模式），如 https://api.kimi.com/coding
AI_BASE_URL=https://api.example.com
# 模型名称，支持 openai/ anthropic/ minimax/ 前缀（可选，默认 openai/doubao-seed-2-0-pro-260215）
AI_MODEL_NAME=anthropic/kimi-for-coding

# ---------- 浏览器配置（真实模式可选，均有默认值） ----------
# 是否无头模式启动 Chromium（默认 true）
CRAWLER_HEADLESS=true
# 浏览器视口宽度（默认 1024）
CRAWLER_VIEWPORT_WIDTH=1024
# 浏览器视口高度（默认 768）
CRAWLER_VIEWPORT_HEIGHT=768
# 文本模式，跳过图片等资源加载（默认 true）
CRAWLER_TEXT_MODE=true
# crawl4ai 详细日志（默认 false）
CRAWLER_VERBOSE=false

# ---------- 运行模式 ----------
# mock 模拟爬取模式：true 时不请求真实网络/浏览器/LLM，生成假数据（默认 false）
USE_MOCK_CRAWLER=false

# ---------- 数据库 ----------
# SQLite 数据库路径（可选；默认 <skill目录>/../data/crawler.db，也可用 --db-path 覆盖）
CRAWLER_DB_PATH=
